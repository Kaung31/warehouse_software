{
  "name": "scooter-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest --config vitest.integration.config.ts run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "db:branch": "tsx scripts/neon-branch.ts",
    "db:migrate:staging": "DATABASE_URL=$NEON_STAGING_DATABASE_URL DIRECT_URL=$NEON_STAGING_DIRECT_URL prisma migrate deploy",
    "db:reset:dev": "tsx scripts/neon-reset.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@clerk/nextjs": "^7.2.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.52.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@trigger.dev/sdk": "^4.0.0",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.0.9",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pino": "^9.5.0",
    "posthog-js": "^1.197.0",
    "posthog-node": "^4.10.0",
    "prisma": "^5.22.0",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.5.0",
    "twilio": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@trigger.dev/build": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pino-pretty": "^11.3.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
