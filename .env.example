# ScooterHub — environment variables.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://scooter:localdevpassword@localhost:5432/scooterhub"

# ── Clerk auth ────────────────────────────────────────────────────────
# Get these from your Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL="/sign-in"

# ── Cloudflare R2 (file storage) ─────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── DPD (shipping) ───────────────────────────────────────────────────
DPD_API_KEY=""
DPD_API_PASSWORD=""
DPD_ACCOUNT_NUMBER=""
DPD_SENDER_NAME=""
DPD_SENDER_STREET=""
DPD_SENDER_CITY=""
DPD_SENDER_POSTCODE=""

# ── Phase B: customer tracking portal ────────────────────────────────
# Signing secret for the public /track tokens. MUST be set, MUST be at
# least 32 random chars in production (we hard-fail if it's shorter
# than 16). Generate with: `openssl rand -hex 32`.
TRACK_TOKEN_SECRET="change-me-to-a-32-plus-char-random-string"

# Public URL the notification system uses to build tracking links sent
# to customers. Defaults to http://localhost:3000 when unset, which is
# fine for local testing.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Phase B: outbound notification providers ─────────────────────────
# Resend — email. Get an API key at resend.com. Without this, email
# sends are recorded as FAILED rows with a clear "key missing" error,
# but the API call that triggered them still succeeds.
RESEND_API_KEY=""
NOTIFICATION_FROM_EMAIL="ScooterHub Repair <noreply@scooterhub.example>"

# Twilio — SMS. Same fail-soft semantics if credentials are missing.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─────────────────────────────────────────────────────────────────────
# Production migration env vars — every block below is fail-soft. If
# the keys are blank the corresponding service silently no-ops; the
# app keeps working.
# ─────────────────────────────────────────────────────────────────────

# Sentry — error tracking. Get from sentry.io project settings.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
SENTRY_ENVIRONMENT="development"
# Set in CI to the git SHA so releases line up.
NEXT_PUBLIC_SENTRY_RELEASE=""
SENTRY_RELEASE=""
# Build-time: source-map upload to Sentry.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Better Stack — log aggregation + uptime + status page.
BETTER_STACK_SOURCE_TOKEN=""
BETTER_STACK_INGESTING_HOST="in.logs.betterstack.com"

# PostHog — session replay + feature flags. EU host by default.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
POSTHOG_API_KEY=""
POSTHOG_HOST="https://eu.i.posthog.com"

# Upstash — already on file in track-rate-limit.ts; explicit here for the
# new cache + lock helpers in Phase 2.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Trigger.dev — background job runner (Phase 3).
TRIGGER_PROJECT_ID=""
TRIGGER_SECRET_KEY=""
TRIGGER_API_URL="https://api.trigger.dev"

# Resend + Twilio webhooks. Set after creating the webhook in each
# provider; used to verify signatures.
RESEND_WEBHOOK_SECRET=""
TWILIO_WEBHOOK_SECRET=""

# Cloudflare Images Transformations (Phase 4). The transformation host
# is the zone Cloudflare proxies for you, e.g. https://scooterhub.co.uk
CLOUDFLARE_IMAGES_HOST=""

# Pusher — real-time channels (Phase 7). Sandbox tier supports 200
# connections (we plan for ~60).
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID=""
PUSHER_SECRET=""

# Neon database (Phase 5). DATABASE_URL is the pooled (Supavisor)
# connection used by the runtime; DIRECT_URL is the unpooled
# connection used by `prisma migrate`.
# DATABASE_URL above; add the unpooled one too:
DIRECT_URL=""
# Per-environment branches for the GitHub Actions workflow + scripts.
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_STAGING_DATABASE_URL=""
NEON_STAGING_DIRECT_URL=""
